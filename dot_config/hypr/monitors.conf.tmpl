# chezmoi source: dot_config/hypr/monitors.conf.tmpl
# chezmoi destination: ~/.config/hypr/monitors.conf
# Ricer's Log:
# 1. Monitor config is templated because display names are machine facts, not design facts.
# 2. The default prefers exact resolution and refresh to avoid accidental low-Hz sessions.
# 3. Laptop scaling remains explicit and conservative.

{{- $monitor := .machine.monitor_name | default "DP-1" -}}
{{- $res := .machine.monitor_res | default "2560x1440" -}}
{{- $rate := .machine.monitor_rate | default "144" -}}
monitor = {{ $monitor }}, {{ $res }}@{{ $rate }}, 0x0, 1 # Primary display from .chezmoidata for deterministic startup.
monitor = , preferred, auto, 1 # Any extra display comes up with sane preferred defaults.

{{ if .machine.is_laptop -}}
workspace = 1, monitor:{{ $monitor }}, default:true # Laptop single-panel default keeps workspace 1 anchored.
{{ else -}}
workspace = 1, monitor:{{ $monitor }}, default:true # Desktop primary anchors the working lane.
workspace = 2, monitor:{{ $monitor }} # Browser follows the primary unless user adds a monitor rule.
workspace = 3, monitor:{{ $monitor }} # Chat follows the primary for predictable notifications.
{{ end -}}

# End Ricer's Log:
# - Machine-specific values are template data, not hardcoded config drift.
# - Fallback monitor line makes hotplug less brittle.
# - Workspace anchoring prevents apps from opening on the wrong panel after login.
